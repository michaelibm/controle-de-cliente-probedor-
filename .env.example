# ──────────────────────────────────────────────────────────────
# ISP Manager — Exemplo de variáveis de ambiente
# Copie para .env e ajuste
# ──────────────────────────────────────────────────────────────

POSTGRES_DB=isp_manager
POSTGRES_USER=isp_user
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA
POSTGRES_PORT=5432

JWT_SECRET=TROQUE_ESTE_SECRET_JWT
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=TROQUE_ESTE_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:80
BACKEND_PORT=3000
FRONTEND_PORT=80

RUN_SEED=true
